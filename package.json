{
  "name": "nju-timetable",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "app/mobile",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev:mobile": "npm run start --workspace @nju/mobile",
    "typecheck": "npm run typecheck --workspace @nju/contracts && npm run typecheck --workspace @nju/domain && npm run typecheck --workspace @nju/mobile",
    "test:domain": "npm run test --workspace @nju/domain",
    "typecheck:contracts": "npm run typecheck --workspace @nju/contracts",
    "typecheck:domain": "npm run typecheck --workspace @nju/domain",
    "typecheck:mobile": "npm run typecheck --workspace @nju/mobile"
  }
}
